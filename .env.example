# Anthropic API key (sk-ant-api03-*)
# Get it from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# User to run the server as (default: t3user).
# Created at image build time — rebuild required to change.
# Set to "root" to run the container as root instead.
RUN_USER=t3user

# Set to true to give RUN_USER passwordless sudo (root access).
# Requires image rebuild to take effect.
GRANT_SUDO=false

# Comma-separated list of domains to block inside the container (no spaces).
# Routed to 0.0.0.0 via /etc/hosts — requires RUN_USER=root.
# Example: BLOCKED_DOMAINS=facebook.com,reddit.com,twitter.com
BLOCKED_DOMAINS=
